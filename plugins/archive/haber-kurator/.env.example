# Memos Platform API Token
# Memos platformu üzerinden profil ayarlarınızdan oluşturduğunuz Access Token (Erişim Anahtarı).
MEMOS_TOKEN="your_memos_access_token_here"

# Memos Platform API URL
# API isteklerinin yapılacağı uç nokta adresi. Varsayılan olarak googig.cloud yapısına ayarlanmıştır.
MEMOS_API_URL="https://memos.googig.cloud/api/v1/memos"
